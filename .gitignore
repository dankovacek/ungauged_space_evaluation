# XGBoost models: keep only the selected trial (trial 6, proximity_plus_attributes).
# All other model files come from dankovacek/divergence_prediction and are not tracked.
data/xgb_models/proximity_*.json
data/xgb_models/physical_attributes_*.json
!data/xgb_models/proximity_plus_attributes_trial6_*.json
data/BCUB_regions_merged_R0.geojson


# KLD prediction results: keep only the compact trial summary CSV, not the large .npy.
data/KLD_prediction_results/*.npy

